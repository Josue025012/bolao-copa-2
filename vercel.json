{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/estilo.css", "dest": "/estilo.css" },
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/index.php", "dest": "/api/index.php" },
    { "src": "/ranking.php", "dest": "/api/ranking.php" },
    { "src": "/admin.php", "dest": "/api/admin.php" },
    { "src": "/login.php", "dest": "/api/login.php" },
    { "src": "/cadastro.php", "dest": "/api/cadastro.php" }
  ]
}